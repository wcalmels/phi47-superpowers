{
  "name": "phi47-superpowers",
  "displayName": "Phi47 Superpowers",
  "description": "Structural code quality linter based on Integrated Information Theory (IIT 4.0). Detects zombie functions, low Phi, and fragmented codebases.",
  "version": "0.1.3",
  "publisher": "wcalmels",
  "icon": "images/phi47-icon.png",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Linters", "Other"],
  "keywords": [
    "linter",
    "phi",
    "iit",
    "code quality",
    "python",
    "structural analysis",
    "zombie functions"
  ],
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/wcalmels/phi47-superpowers"
  },
  "bugs": {
    "url": "https://github.com/wcalmels/phi47-superpowers/issues"
  },
  "homepage": "https://github.com/wcalmels/phi47-superpowers#readme",
  "license": "MIT",
  "activationEvents": ["onLanguage:python"],
  "main": "./out/extension.js",
  "extensionRecommendations": [
    "wcalmels.resonance"
  ],
  "contributes": {
    "commands": [
      {
        "command": "phi47.analyzeFile",
        "title": "Phi47: Analyze Current File",
        "category": "Phi47"
      },
      {
        "command": "phi47.analyzeWorkspace",
        "title": "Phi47: Analyze Workspace",
        "category": "Phi47"
      },
      {
        "command": "phi47.showReport",
        "title": "Phi47: Show Phi Report",
        "category": "Phi47"
      },
      {
        "command": "phi47.resonancePipeline",
        "title": "Phi47 + Resonance: Generate Module with Quality Pipeline",
        "category": "Phi47"
      }
    ],
    "configuration": {
      "title": "Phi47",
      "properties": {
        "phi47.pythonPath": {
          "type": "string",
          "default": "",
          "description": "Python executable with phi47-superpowers installed (default: python3, or py -3 on Windows)"
        },
        "phi47.enableOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Run Phi47 analysis when a Python file is saved"
        },
        "phi47.phiErrorThreshold": {
          "type": "number",
          "default": 0.3,
          "description": "Phi below this value triggers an error diagnostic"
        },
        "phi47.phiWarningThreshold": {
          "type": "number",
          "default": 0.5,
          "description": "Phi below this value triggers a warning diagnostic"
        },
        "phi47.showStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "Show Phi value in the status bar"
        }
      }
    },
    "menus": {
      "editor/context": [
        {
          "command": "phi47.analyzeFile",
          "when": "editorLangId == python",
          "group": "phi47@1"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.24.0",
    "typescript": "^5.3.0"
  }
}
